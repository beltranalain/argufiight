{
  "expo": {
    "name": "ArguFight",
    "slug": "argufight",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "argufight",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0c0c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.argufight.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "ArguFight needs access to your camera to take profile photos.",
        "NSPhotoLibraryUsageDescription": "ArguFight needs access to your photos to upload a profile picture.",
        "NSFaceIDUsageDescription": "ArguFight uses Face ID to securely unlock your account."
      },
      "associatedDomains": [
        "applinks:www.argufight.com"
      ]
    },
    "android": {
      "package": "com.argufight.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.argufight.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-notifications",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "4cd7fd74-7cdf-4b7c-b8fd-2a5e1a9e4725"
      }
    },
    "owner": "donkeyideass"
  }
}
